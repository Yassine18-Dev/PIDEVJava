<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.MatchPredictionController"
      spacing="22"
      prefWidth="760"
      prefHeight="820"
      maxWidth="760"
      stylesheets="@novos.css"
      styleClass="premium-modal">

    <HBox spacing="18" alignment="CENTER_LEFT">
        <Label text="🤖" prefWidth="90" prefHeight="90" styleClass="premium-icon-main"/>
        <VBox spacing="8">
            <Label text="PRÉDICTION IA" styleClass="premium-tag"/>
            <Label text="Analyse du match" styleClass="premium-header-title"/>
            <Label text="Résultat généré par l’IA " styleClass="premium-header-subtitle"/>
        </VBox>
    </HBox>

    <VBox spacing="14" styleClass="prediction-window-card">
        <Label fx:id="lblPrediction"
               wrapText="true"
               styleClass="prediction-window-text"/>
    </VBox>

    <Button text="← Retour"
            prefWidth="320"
            styleClass="btn-primary"
            onAction="#retour"/>

</VBox>