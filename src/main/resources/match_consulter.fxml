<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.MatchConsulterController"
      spacing="18"
      prefWidth="620"
      maxWidth="620"
      stylesheets="@novos.css"
      styleClass="premium-modal">

    <HBox spacing="18" alignment="CENTER_LEFT">
        <Label text="🎮" prefWidth="70" prefHeight="70" styleClass="premium-icon-main"/>
        <VBox spacing="6">
            <Label text="DÉTAILS" styleClass="premium-tag"/>
            <Label text="Consulter un match" styleClass="premium-header-title"/>
        </VBox>
    </HBox>

    <VBox spacing="12">

        <Label text="Équipe 1 :" styleClass="premium-label"/>
        <Label fx:id="lblEquipe1" styleClass="premium-value"/>

        <Label text="Équipe 2 :" styleClass="premium-label"/>
        <Label fx:id="lblEquipe2" styleClass="premium-value"/>

        <Label text="Date :" styleClass="premium-label"/>
        <Label fx:id="lblDateMatch" styleClass="premium-value"/>

        <Label text="Heure :" styleClass="premium-label"/>
        <Label fx:id="lblHeureMatch" styleClass="premium-value"/>

        <Label text="Score :" styleClass="premium-label"/>
        <Label fx:id="lblScore" styleClass="premium-value"/>

    </VBox>

    <Button text="← Retour"
            prefWidth="250"
            styleClass="btn-primary"
            onAction="#retour"/>

</VBox>