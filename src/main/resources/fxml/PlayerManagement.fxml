<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.PlayerController">

    <top>
        <VBox spacing="10.0">
            <padding>
                <Insets top="20.0" right="20.0" bottom="10.0" left="20.0"/>
            </padding>
            <children>
                <Label text="Gestion des joueurs" styleClass="title-label"/>
                <TextField fx:id="searchField" promptText="Rechercher par pseudo"/>
            </children>
        </VBox>
    </top>

    <center>
        <TableView fx:id="playerTable">
            <columns>
                <TableColumn fx:id="colId" prefWidth="70.0" text="ID"/>
                <TableColumn fx:id="colUsername" prefWidth="160.0" text="Pseudo"/>
                <TableColumn fx:id="colEmail" prefWidth="220.0" text="Email"/>
                <TableColumn fx:id="colGame" prefWidth="120.0" text="Jeu"/>
                <TableColumn fx:id="colRank" prefWidth="150.0" text="Rank"/>
                <TableColumn fx:id="colTeam" prefWidth="120.0" text="Équipe"/>
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="12.0" styleClass="card" prefWidth="300.0">
            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>
            <children>
                <Label text="Formulaire joueur"/>
                <TextField fx:id="usernameField" promptText="Pseudo"/>
                <TextField fx:id="emailField" promptText="Email"/>
                <PasswordField fx:id="passwordField" promptText="Mot de passe"/>
                <ComboBox fx:id="gameBox" promptText="Jeu"/>
                <TextField fx:id="rankField" promptText="Rank"/>
                <TextField fx:id="leaguePointsField" promptText="League Points"/>
                <TextField fx:id="teamIdField" promptText="Team ID"/>
            </children>
        </VBox>
    </right>

    <bottom>
        <HBox spacing="10.0" alignment="CENTER">
            <padding>
                <Insets top="15.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>
            <children>
                <Button text="Ajouter" onAction="#addPlayer" prefWidth="120.0"/>
                <Button text="Modifier" onAction="#updatePlayer" prefWidth="120.0"/>
                <Button text="Supprimer" onAction="#deletePlayer" prefWidth="120.0" styleClass="danger-button"/>
                <Button text="Rechercher" onAction="#searchPlayer" prefWidth="120.0"/>
                <Button text="Filtrer jeu" onAction="#filterByGame" prefWidth="120.0"/>
                <Button text="Top 3" onAction="#showTop3" prefWidth="120.0"/>
                <Button text="Sans équipe" onAction="#showFreeAgents" prefWidth="120.0"/>
                <Button text="Refresh" onAction="#refreshPlayers" prefWidth="120.0"/>
                <Button text="Retour" onAction="#goBack" prefWidth="120.0" styleClass="secondary-button"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>