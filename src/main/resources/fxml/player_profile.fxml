<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.PlayerProfileController"
            stylesheets="@../css/style.css">

    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="8">
            <padding><Insets top="30" right="15" bottom="20" left="15"/></padding>
            <Label text="ArenaMind" styleClass="sidebar-logo"/>
            <Region prefHeight="20"/>
            <Button text="🏠  Profile"     styleClass="sidebar-btn-active" maxWidth="Infinity"/>
            <Button text="👥  My Team"     styleClass="sidebar-btn" onAction="#openMyTeam" maxWidth="Infinity"/>
            <Button fx:id="invitationsBtn" text="📩  Invitations" styleClass="sidebar-btn"
                    onAction="#openInvitations" maxWidth="Infinity"/>
            <Button text="🏆  Tournaments" styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="🔄  Switch User" styleClass="sidebar-btn" onAction="#switchUser" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" styleClass="transparent-scroll">
            <VBox spacing="20">
                <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>

                <HBox styleClass="card" spacing="20" alignment="CENTER_LEFT">
                    <StackPane onMouseClicked="#changeAvatar" styleClass="avatar-clickable">
                        <Circle radius="55" styleClass="avatar-bg"/>
                        <ImageView fx:id="avatarView" fitWidth="100" fitHeight="100" preserveRatio="true"/>
                        <Label text="📷" styleClass="avatar-edit-icon"/>
                    </StackPane>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <TextField fx:id="usernameField" styleClass="title-field"/>
                        <TextField fx:id="emailField"    styleClass="subtitle-field"/>
                        <HBox spacing="10">
                            <Label fx:id="gameBadge" text="LOL" styleClass="game-badge"/>
                            <Label fx:id="rankBadge" text="UNRANKED" styleClass="rank-badge"/>
                            <Label fx:id="captainBadge" text="⭐ CAPITAINE" styleClass="captain-badge"
                                   visible="false" managed="false"/>
                        </HBox>
                    </VBox>

                    <VBox alignment="CENTER" spacing="2">
                        <Label text="SKILL SCORE" styleClass="score-label"/>
                        <Label fx:id="skillScoreLabel" text="0" styleClass="score-value"/>
                        <Label fx:id="aboveAvgLabel" text="" styleClass="score-pct"/>
                    </VBox>
                </HBox>

                <HBox spacing="20">
                    <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="10">
                        <Label text="POINTS FORTS" styleClass="card-title"/>
                        <Label text="Spider chart de tes 5 dimensions" styleClass="subtitle-label"/>
                        <StackPane fx:id="radarContainer" prefHeight="380"/>
                    </VBox>

                    <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="14">
                        <Label text="VS RANK AVERAGE" styleClass="card-title"/>
                        <Label text="Comparaison à la moyenne des joueurs du même rank"
                               styleClass="subtitle-label"/>
                        <VBox fx:id="comparisonBox" spacing="14"/>
                    </VBox>
                </HBox>

                <HBox spacing="20">
                    <VBox fx:id="discordCardContainer" HBox.hgrow="ALWAYS" spacing="0"
                          minWidth="320"/>

                    <VBox fx:id="teamCard" styleClass="card" HBox.hgrow="ALWAYS" spacing="12">
                        <Label text="ÉQUIPE ACTUELLE" styleClass="card-title"/>
                        <VBox fx:id="teamBox" spacing="8"/>
                        <Button fx:id="teamActionBtn" text="VOIR MON ÉQUIPE"
                                onAction="#openMyTeam" styleClass="button" maxWidth="Infinity"/>
                    </VBox>
                </HBox>

                <VBox fx:id="championsCardContainer" spacing="0"/>

                <HBox spacing="10">
                    <Button text="💾 SAUVEGARDER" onAction="#saveProfile"
                            styleClass="button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="🎲 AVATAR ALÉATOIRE" onAction="#generateRandomAvatar"
                            styleClass="secondary-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>