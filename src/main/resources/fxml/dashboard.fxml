<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="700.0" prefWidth="1100.0" spacing="20.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.DashboardController">
    <padding>
        <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
    </padding>

    <children>
        <Label text="Arena MIND" styleClass="title-label"/>
        <Label text="Access your Esport dashboard" styleClass="subtitle-label"/>

        <VBox alignment="CENTER" spacing="18.0" styleClass="card" maxWidth="500.0">
            <children>
                <Button text="Gérer les équipes" prefWidth="250.0" onAction="#goToTeams"/>
                <Button text="Gérer les joueurs" prefWidth="250.0" onAction="#goToPlayers"/>
                <Button text="Quitter" prefWidth="250.0" onAction="#quitApp"/>
            </children>
        </VBox>
    </children>
</VBox>