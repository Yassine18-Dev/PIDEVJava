<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.InvitationsViewController"
            stylesheets="@../css/style.css">

    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="8">
            <padding><Insets top="30" right="15" bottom="20" left="15"/></padding>
            <Label text="ArenaMind" styleClass="sidebar-logo"/>
            <Region prefHeight="20"/>
            <Button text="🏠  Profile"     styleClass="sidebar-btn"
                    onAction="#backToProfile" maxWidth="Infinity"/>
            <Button text="👥  My Team"     styleClass="sidebar-btn"
                    onAction="#backToTeam"    maxWidth="Infinity"/>
            <Button text="📩  Invitations" styleClass="sidebar-btn-active" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" styleClass="transparent-scroll">
            <VBox spacing="20">
                <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>

                <Label text="📩 MES INVITATIONS" styleClass="title-label"/>

                <VBox styleClass="card" spacing="10">
                    <Label text="EN ATTENTE" styleClass="card-title"/>
                    <VBox fx:id="pendingBox" spacing="10"/>
                </VBox>

                <VBox styleClass="card" spacing="10">
                    <Label text="HISTORIQUE" styleClass="card-title"/>
                    <VBox fx:id="historyBox" spacing="8"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>