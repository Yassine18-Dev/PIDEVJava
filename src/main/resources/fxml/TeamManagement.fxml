<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.TeamController">

    <top>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="20.0" right="20.0" bottom="10.0" left="20.0"/>
            </padding>
            <children>
                <Label text="Gestion des équipes" styleClass="title-label"/>
                <TextField fx:id="searchField" promptText="Rechercher par nom d'équipe"/>
            </children>
        </VBox>
    </top>

    <center>
        <TableView fx:id="teamTable" prefWidth="700.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="70.0" text="ID"/>
                <TableColumn fx:id="colName" prefWidth="180.0" text="Nom"/>
                <TableColumn fx:id="colGame" prefWidth="120.0" text="Jeu"/>
                <TableColumn fx:id="colPlayers" prefWidth="150.0" text="Joueurs"/>
                <TableColumn fx:id="colPowerScore" prefWidth="140.0" text="Power Score"/>
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="12.0" styleClass="card" prefWidth="280.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>
            <children>
                <Label text="Formulaire équipe"/>
                <TextField fx:id="nameField" promptText="Nom"/>
                <ComboBox fx:id="gameBox" promptText="Jeu"/>
                <TextField fx:id="maxPlayersField" promptText="Max Players"/>
                <TextField fx:id="currentPlayersField" promptText="Current Players"/>
                <TextField fx:id="powerScoreField" promptText="Power Score"/>
            </children>
        </VBox>
    </right>

    <bottom>
        <HBox spacing="10.0" alignment="CENTER">
            <padding>
                <Insets top="15.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>
            <children>
                <Button text="Ajouter" onAction="#addTeam" prefWidth="120.0"/>
                <Button text="Modifier" onAction="#updateTeam" prefWidth="120.0"/>
                <Button text="Supprimer" onAction="#deleteTeam" prefWidth="120.0" styleClass="danger-button"/>
                <Button text="Rechercher" onAction="#searchTeam" prefWidth="120.0"/>
                <Button text="Trier" onAction="#sortByPowerScore" prefWidth="120.0"/>
                <Button text="Recrutent" onAction="#showRecruitingTeams" prefWidth="120.0"/>
                <Button text="Refresh" onAction="#refreshTeams" prefWidth="120.0"/>
                <Button text="Retour" onAction="#goBack" prefWidth="120.0" styleClass="secondary-button"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>