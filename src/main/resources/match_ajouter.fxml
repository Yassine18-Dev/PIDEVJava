<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.MatchAjouterController"
      spacing="14"
      prefWidth="620"
      maxWidth="620"
      stylesheets="@novos.css"
      styleClass="premium-modal">

    <HBox spacing="18" alignment="CENTER_LEFT">
        <Label text="+" prefWidth="70" prefHeight="70" styleClass="premium-icon-main"/>
        <VBox spacing="6">
            <Label text="NOUVEAU" styleClass="premium-tag"/>
            <Label text="Ajouter un match" styleClass="premium-header-title"/>
            <Label text="Ajoutez une nouvelle rencontre e-sport" styleClass="premium-header-subtitle"/>
        </VBox>
    </HBox>

    <VBox spacing="10">

        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="premium-row,premium-row-pink">
            <Label text="👥" prefWidth="54" prefHeight="54" styleClass="premium-icon"/>
            <VBox>
                <Label text="ÉQUIPE 1" styleClass="premium-label"/>
                <ComboBox fx:id="cbTeam1"
                          promptText="Choisir équipe 1"
                          prefWidth="420"
                          styleClass="premium-input"/>
            </VBox>
        </HBox>

        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="premium-row,premium-row-blue">
            <Label text="👥" prefWidth="54" prefHeight="54" styleClass="premium-icon,premium-icon-blue"/>
            <VBox>
                <Label text="ÉQUIPE 2" styleClass="premium-label,premium-label-blue"/>
                <ComboBox fx:id="cbTeam2"
                          promptText="Choisir équipe 2"
                          prefWidth="420"
                          styleClass="premium-input"/>
            </VBox>
        </HBox>

        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="premium-row,premium-row-pink">
            <Label text="📅" prefWidth="54" prefHeight="54" styleClass="premium-icon"/>
            <VBox>
                <Label text="DATE DU MATCH" styleClass="premium-label"/>
                <DatePicker fx:id="dpDateMatch"
                            promptText="Sélectionnez la date"
                            prefWidth="420"
                            styleClass="premium-date"/>
            </VBox>
        </HBox>

        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="premium-row,premium-row-blue">
            <Label text="⏰" prefWidth="54" prefHeight="54" styleClass="premium-icon,premium-icon-blue"/>
            <VBox>
                <Label text="HEURE DU MATCH" styleClass="premium-label,premium-label-blue"/>
                <TextField fx:id="tfHeureMatch"
                           promptText="Ex : 18:30"
                           prefWidth="420"
                           styleClass="premium-input"/>
            </VBox>
        </HBox>

        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="premium-row,premium-row-purple">
            <Label text="🏁" prefWidth="54" prefHeight="54" styleClass="premium-icon,premium-icon-purple"/>
            <VBox>
                <Label text="SCORE" styleClass="premium-label,premium-label-purple"/>
                <TextField fx:id="tfScore"
                           promptText="Ex : 2-1"
                           prefWidth="420"
                           styleClass="premium-input"/>
            </VBox>
        </HBox>

        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="premium-row,premium-row-blue">
            <Label text="🏆" prefWidth="54" prefHeight="54" styleClass="premium-icon,premium-icon-blue"/>
            <VBox>
                <Label text="TOURNOI ID" styleClass="premium-label,premium-label-blue"/>
                <TextField fx:id="tfTournoiId"
                           promptText="Ex : 1 ou vide pour match hors tournoi"
                           prefWidth="420"
                           styleClass="premium-input"/>
            </VBox>
        </HBox>

    </VBox>

    <HBox spacing="18" alignment="CENTER">
        <Button text="✕  Annuler"
                prefWidth="190"
                styleClass="btn-secondary"
                onAction="#retour"/>

        <Button text="✓  Ajouter"
                prefWidth="250"
                styleClass="btn-primary"
                onAction="#ajouterMatch"/>
    </HBox>

</VBox>