<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.TournoiSupprimerController"
      spacing="22"
      prefWidth="560"
      maxWidth="560"
      stylesheets="@novos.css"
      styleClass="premium-modal">

    <HBox spacing="18" alignment="CENTER_LEFT">
        <Label text="🗑" prefWidth="70" prefHeight="70" styleClass="premium-icon-main"/>
        <VBox spacing="6">
            <Label text="SUPPRIMER" styleClass="premium-tag"/>
            <Label text="Supprimer un tournoi" styleClass="premium-header-title"/>
            <Label text="Cette action est définitive" styleClass="premium-header-subtitle"/>
        </VBox>
    </HBox>

    <VBox spacing="14" styleClass="premium-danger-box">
        <Label text="Êtes-vous sûr de vouloir supprimer ce tournoi ?" styleClass="premium-value"/>
        <Label fx:id="lblMessage" wrapText="true" styleClass="label-info"/>
    </VBox>

    <HBox spacing="18" alignment="CENTER">
        <Button text="✕  Annuler" prefWidth="190" styleClass="btn-secondary" onAction="#retour"/>
        <Button text="🗑  Supprimer" prefWidth="250" styleClass="btn-danger" onAction="#supprimerTournoi"/>
    </HBox>
</VBox>