<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.TournoiController"
           prefWidth="1100"
           prefHeight="700"
           stylesheets="@novos.css">

    <BorderPane prefWidth="1100" prefHeight="700">

        <left>
            <VBox spacing="26" prefWidth="235" styleClass="sidebar" style="-fx-padding:30;">
                <Label text="ArenaMind" styleClass="logo"/>
                <Label text="ESPORT CONTROL HUB" styleClass="small-text"/>

                <Button text="⌂  Dashboard" prefWidth="175" styleClass="nav-btn"/>
                <Button text="🎮  Matchs" prefWidth="175" styleClass="nav-btn" onAction="#goToMatch"/>
                <Button text="🏆  Tournois" prefWidth="175" styleClass="nav-active"/>


                <Region VBox.vgrow="ALWAYS"/>
                <Label text="v1.0 ArenaMind" styleClass="small-text"/>
            </VBox>
        </left>

        <center>
            <VBox spacing="24" style="-fx-padding:30;">

                <HBox alignment="CENTER_LEFT" spacing="15">
                    <VBox>
                        <Label text="Gestion des Tournois" styleClass="title"/>
                        <Label text="Créer, modifier et supprimer les tournois" styleClass="subtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <TextField fx:id="tfRecherche" promptText="🔍  Rechercher par nom..." prefWidth="260"/>
                    <Button text="Rechercher" styleClass="btn-secondary" onAction="#rechercherTournoi"/>
                    <Button text="Actualiser" styleClass="btn-primary" onAction="#actualiserListe"/>
                </HBox>

                <HBox spacing="20">

                    <!-- TOTAL -->
                    <HBox spacing="18" alignment="CENTER_LEFT" prefWidth="280" styleClass="card">
                        <Label text="🏆" prefWidth="54" prefHeight="54" styleClass="stat-icon"/>
                        <VBox spacing="4">
                            <Label text="TOTAL TOURNOIS" styleClass="stat-label"/>
                            <Label fx:id="lblTotalTournois" text="0" styleClass="stat-number"/>
                            <Label fx:id="lblTotalInfo" text="Tournois enregistrés" styleClass="small-text"/>
                        </VBox>
                    </HBox>

                    <!-- ACTIFS -->
                    <HBox spacing="18" alignment="CENTER_LEFT" prefWidth="280" styleClass="card">
                        <Label text="⚡" prefWidth="54" prefHeight="54" styleClass="stat-icon"/>
                        <VBox spacing="4">
                            <Label text="ACTIFS" styleClass="stat-label"/>
                            <Label fx:id="lblTournoisActifs" text="0" styleClass="stat-number"/>
                            <Label fx:id="lblActifsInfo" text="Tournois en cours" styleClass="small-text"/>
                        </VBox>
                    </HBox>

                    <!-- TERMINÉS -->
                    <HBox spacing="18" alignment="CENTER_LEFT" prefWidth="280" styleClass="card">
                        <Label text="✓" prefWidth="54" prefHeight="54" styleClass="stat-icon"/>
                        <VBox spacing="4">
                            <Label text="TERMINÉS" styleClass="stat-label"/>
                            <Label fx:id="lblTournoisTermines" text="0" styleClass="stat-number"/>
                            <Label fx:id="lblTerminesInfo" text="0% du total" styleClass="small-text"/>
                        </VBox>
                    </HBox>

                </HBox>
                <HBox spacing="20" VBox.vgrow="ALWAYS">

                    <VBox spacing="14" prefWidth="720" styleClass="card-dark">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="☷" prefWidth="34" prefHeight="34" styleClass="section-icon"/>
                            <VBox>
                                <Label text="Liste des tournois" styleClass="section-title"/>
                                <Label text="Survolez une ligne pour modifier ou supprimer" styleClass="small-text"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Tournois" styleClass="badge-ended"/>
                        </HBox>

                        <HBox spacing="20" style="-fx-padding: 0 14 0 54;">
                            <Label text="NOM DU TOURNOI" prefWidth="150" styleClass="row-header"/>
                            <Label text="LIEU" prefWidth="90" styleClass="row-header"/>
                            <Label text="DATE DÉBUT" prefWidth="100" styleClass="row-header"/>
                            <Label text="DATE FIN" prefWidth="100" styleClass="row-header"/>
                            <Label text="PRIX / STATUT" prefWidth="115" styleClass="row-header"/>
                            <Label text="ACTIONS" prefWidth="110" styleClass="row-header"/>
                        </HBox>

                        <ListView fx:id="listTournois" prefHeight="390" VBox.vgrow="ALWAYS" styleClass="pro-list"/>
                    </VBox>

                    <VBox spacing="14" prefWidth="320" styleClass="card-dark">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="☷" prefWidth="34" prefHeight="34" styleClass="section-icon"/>
                            <Label text="Détails du tournoi" styleClass="section-title"/>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="detail-line">
                            <Label text="📄" prefWidth="38" prefHeight="38" styleClass="detail-icon"/>
                            <VBox>
                                <Label text="Nom" styleClass="stat-label"/>
                                <Label fx:id="lblNom" text="-" styleClass="label-info"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="detail-line">
                            <Label text="📍" prefWidth="38" prefHeight="38" styleClass="detail-icon"/>
                            <VBox>
                                <Label text="Lieu" styleClass="stat-label"/>
                                <Label fx:id="lblLieu" text="-" styleClass="label-info"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="detail-line">
                            <Label text="📅" prefWidth="38" prefHeight="38" styleClass="detail-icon"/>
                            <VBox>
                                <Label text="Date début" styleClass="stat-label"/>
                                <Label fx:id="lblDateDebut" text="-" styleClass="label-info"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="detail-line">
                            <Label text="📅" prefWidth="38" prefHeight="38" styleClass="detail-icon"/>
                            <VBox>
                                <Label text="Date fin" styleClass="stat-label"/>
                                <Label fx:id="lblDateFin" text="-" styleClass="label-info"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="detail-line">
                            <Label text="💳" prefWidth="38" prefHeight="38" styleClass="detail-icon"/>
                            <VBox>
                                <Label text="Prix / Participants" styleClass="stat-label"/>
                                <Label fx:id="lblPrixInscription" text="-" wrapText="true" styleClass="label-info"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="detail-line">
                            <Label text="👥" prefWidth="38" prefHeight="38" styleClass="detail-icon"/>
                            <VBox>
                                <Label text="Team à inscrire" styleClass="stat-label"/>
                                <ComboBox fx:id="cbTeams"
                                          promptText="Choisir une team"
                                          prefWidth="220"
                                          styleClass="premium-input"/>
                            </VBox>
                        </HBox>

                        <Region VBox.vgrow="ALWAYS"/>

                        <Button text="💳 Inscrire une team &amp; Payer"
                                prefWidth="282"
                                styleClass="btn-primary"
                                onAction="#payerInscription"/>
                    </VBox>
                </HBox>
            </VBox>
        </center>
    </BorderPane>

    <StackPane fx:id="modalOverlay"
               visible="false"
               managed="false"
               pickOnBounds="true"
               styleClass="modal-overlay">
        <Region styleClass="modal-backdrop"/>
        <StackPane fx:id="modalContent" styleClass="modal-content"/>
    </StackPane>

</StackPane>