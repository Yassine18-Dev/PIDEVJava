<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<VBox fx:controller="controllers.AllProductsController"
      xmlns:fx="http://javafx.com/fxml"
      spacing="20" styleClass="content-area"
      prefWidth="900" prefHeight="700"
      style="-fx-background-color: #0F172A;"
      stylesheets="@../styles.css">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="All Products"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🛒 Cart" styleClass="button-primary" onAction="#showCarte"/>
        <Button text="Add Product" styleClass="button-success" onAction="#showAddProduct"/>
    </HBox>

    <!-- Search and Filters -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" prefWidth="300" promptText="Search products..." styleClass="search-box"/>
        <ComboBox fx:id="typeFilterComboBox" prefWidth="120" promptText="Type" styleClass="filter-combo"/>
        <ComboBox fx:id="priceFilterComboBox" prefWidth="150" promptText="Price Range" styleClass="filter-combo"/>
        <Button text="Search" styleClass="button-primary" onAction="#searchProducts"/>
        <Button text="Clear" styleClass="button-secondary" onAction="#clearFilters"/>
    </HBox>

    <!-- Results Count -->
    <Label fx:id="resultsLabel" text="Loading products..." 
           style="-fx-font-size: 14px; -fx-text-fill: #9CA3AF;"/>

    <!-- Products Grid -->
    <ScrollPane prefHeight="500" prefWidth="900" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="ALWAYS">
        <FlowPane fx:id="productsFlowPane" hgap="25" vgap="25" prefWidth="900" alignment="CENTER"/>
    </ScrollPane>

</VBox>
