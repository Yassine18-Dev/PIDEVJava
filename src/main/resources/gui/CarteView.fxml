<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<VBox fx:controller="controllers.CarteController"
      xmlns:fx="http://javafx.com/fxml"
      spacing="15" styleClass="content-area"
      prefWidth="900" prefHeight="800"
      style="-fx-background-color: #0F172A;"
      stylesheets="@../styles.css">

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
        <VBox spacing="15" prefWidth="860">
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Button text="← Back" styleClass="button-secondary" onAction="#goBack"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Shopping Cart"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>
                <Button text="Clear Cart" styleClass="button-danger" onAction="#clearCart"/>
            </HBox>

            <!-- Empty Cart Message -->
            <Label fx:id="emptyCartLabel" text="Your cart is empty"
                   style="-fx-font-size: 18px; -fx-text-fill: #9CA3AF; -fx-font-style: italic;"
                   visible="false" managed="false"/>

            <!-- Cart Items -->
            <VBox fx:id="cartItemsVBox" spacing="15" prefWidth="860"/>

            <!-- Promo Code Section -->
            <VBox spacing="10" styleClass="product-card" prefWidth="860" alignment="CENTER">
                <HBox spacing="10" alignment="CENTER">
                    <TextField fx:id="promoCodeField" promptText="Enter promo code" prefWidth="200"
                              style="-fx-background-color: #1E293B; -fx-text-fill: #FFFFFF; -fx-border-color: #475569; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                    <Button text="Apply" styleClass="button-primary" prefWidth="100" onAction="#applyPromoCode"/>
                </HBox>
                <Label fx:id="promoMessageLabel" text=""
                       style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;"/>
            </VBox>

            <!-- Loyalty Section -->
            <VBox spacing="10" styleClass="product-card" prefWidth="860" alignment="CENTER">
                <HBox spacing="20" alignment="CENTER">
                    <VBox spacing="5" alignment="CENTER">
                        <Label text="Your Points" style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;"/>
                        <Label fx:id="loyaltyPointsLabel" text="0" styleClass="product-price"/>
                    </VBox>
                    <VBox spacing="5" alignment="CENTER">
                        <Label text="Tier" style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;"/>
                        <Label fx:id="loyaltyTierLabel" text="BRONZE" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #CD7F32;"/>
                    </VBox>
                    <VBox spacing="5" alignment="CENTER">
                        <Label text="Tier Discount" style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;"/>
                        <Label fx:id="loyaltyDiscountLabel" text="0%" style="-fx-font-size: 14px; -fx-text-fill: #06B6D4;"/>
                    </VBox>
                </HBox>
                <ProgressBar fx:id="loyaltyProgressBar" prefWidth="400" progress="0"
                             style="-fx-accent: #06B6D4;"/>
                <Label fx:id="loyaltyProgressLabel" text="0 / 500 points to Silver"
                       style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"/>
                <HBox spacing="10" alignment="CENTER">
                    <TextField fx:id="pointsToRedeemField" promptText="Points (100 = 1 TND)" prefWidth="150"
                              style="-fx-background-color: #1E293B; -fx-text-fill: #FFFFFF; -fx-border-color: #475569; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                    <Button text="Redeem" styleClass="button-primary" prefWidth="100" onAction="#redeemPoints"/>
                </HBox>
                <Label fx:id="redeemMessageLabel" text=""
                       style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;"/>
            </VBox>

            <!-- Summary -->
            <VBox spacing="15" styleClass="product-card" prefWidth="860" alignment="CENTER">
                <HBox spacing="30" alignment="CENTER">
                    <VBox spacing="5" alignment="CENTER">
                        <Label text="Total Items" style="-fx-font-size: 14px; -fx-text-fill: #9CA3AF;"/>
                        <Label fx:id="totalItemsLabel" text="0" styleClass="product-price"/>
                    </VBox>
                    <VBox spacing="5" alignment="CENTER">
                        <Label text="Total Price" style="-fx-font-size: 14px; -fx-text-fill: #9CA3AF;"/>
                        <Label fx:id="totalPriceLabel" text="0.00 TND" styleClass="product-price"/>
                    </VBox>
                </HBox>
                <Button text="Checkout" styleClass="button-primary" prefWidth="200" onAction="#checkout"/>
            </VBox>
        </VBox>
    </ScrollPane>

</VBox>
