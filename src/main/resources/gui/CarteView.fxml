<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<VBox fx:controller="controllers.CarteController"
      xmlns:fx="http://javafx.com/fxml"
      spacing="20" styleClass="content-area"
      prefWidth="900" prefHeight="700"
      style="-fx-background-color: #0F172A;"
      stylesheets="@../styles.css">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <Button text="← Back" styleClass="button-secondary" onAction="#goBack"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Shopping Cart" 
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>
        <Button text="Clear Cart" styleClass="button-danger" onAction="#clearCart"/>
    </HBox>

    <!-- Cart Items -->
    <ScrollPane prefHeight="400" prefWidth="900" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
        <VBox fx:id="cartItemsVBox" spacing="15" prefWidth="860"/>
    </ScrollPane>

    <!-- Empty Cart Message -->
    <Label fx:id="emptyCartLabel" text="Your cart is empty" 
           style="-fx-font-size: 18px; -fx-text-fill: #9CA3AF; -fx-font-style: italic;"
           visible="false" managed="false"/>

    <!-- Summary -->
    <VBox spacing="15" styleClass="product-card" prefWidth="860" alignment="CENTER">
        <HBox spacing="30" alignment="CENTER">
            <VBox spacing="5" alignment="CENTER">
                <Label text="Total Items" style="-fx-font-size: 14px; -fx-text-fill: #9CA3AF;"/>
                <Label fx:id="totalItemsLabel" text="0" styleClass="product-price"/>
            </VBox>
            <VBox spacing="5" alignment="CENTER">
                <Label text="Total Price" style="-fx-font-size: 14px; -fx-text-fill: #9CA3AF;"/>
                <Label fx:id="totalPriceLabel" text="0.00 TND" styleClass="product-price"/>
            </VBox>
        </HBox>
        <Button text="Checkout" styleClass="button-primary" prefWidth="200" onAction="#checkout"/>
    </VBox>

</VBox>
