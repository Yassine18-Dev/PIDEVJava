<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="controllers.ProductFormController" 
           fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
    
    <VBox spacing="20" alignment="CENTER" styleClass="main-container"
          prefWidth="800" prefHeight="700" style="-fx-background-color: #0F172A;" stylesheets="@../styles.css">

    <!-- Header -->
    <Label fx:id="formTitleLabel" text="Add New Product" 
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>

    <!-- Form Container -->
    <VBox spacing="20" prefWidth="500" alignment="CENTER">

        <!-- Product Type -->
        <VBox spacing="5">
            <Label text="Product Type" styleClass="form-label"/>
            <HBox spacing="15">
                <RadioButton fx:id="skinRadioButton" text="Skin" selected="true"/>
                <RadioButton fx:id="merchRadioButton" text="Merch"/>
            </HBox>
            <Label text="Choisissez le type de produit (Skin ou Merch)" 
                   style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF; -fx-font-style: italic;"/>
        </VBox>

        <!-- Name -->
        <VBox spacing="5">
            <Label text="Name" styleClass="form-label"/>
            <TextField fx:id="nameField" promptText="Enter product name" styleClass="form-field" prefWidth="400"/>
            <Label text="Minimum 3 caractères requis" 
                   style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF; -fx-font-style: italic;"/>
        </VBox>

        <!-- Price -->
        <VBox spacing="5">
            <Label text="Price (TND)" styleClass="form-label"/>
            <TextField fx:id="priceField" promptText="0.00" styleClass="form-field" prefWidth="400"/>
            <Label text="Prix entre 0 et 10000 TND" 
                   style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF; -fx-font-style: italic;"/>
        </VBox>

        <!-- Description -->
        <VBox spacing="5">
            <Label text="Description" styleClass="form-label"/>
            <TextArea fx:id="descriptionField" promptText="Enter product description" 
                     styleClass="form-field" prefWidth="400" prefHeight="80" wrapText="true"/>
            <Label text="Optionnel - Maximum 500 caractères" 
                   style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF; -fx-font-style: italic;"/>
        </VBox>

        <!-- Image -->
        <VBox spacing="5">
            <Label text="Image URL/Path" styleClass="form-label"/>
            <HBox spacing="10">
                <TextField fx:id="imageField" promptText="Enter image path or URL" 
                         styleClass="form-field" prefWidth="300"/>
                <Button text="Browse" styleClass="button-secondary" onAction="#browseImage"/>
                <Button text="🤖 IA" styleClass="secondary-button" onAction="#analyzeImageWithAI" prefWidth="80"/>
            </HBox>
            <Label text="Formats acceptés: jpg, jpeg, png, gif, bmp | IA analyse automatiquement l'image" 
                   style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF; -fx-font-style: italic;"/>
        </VBox>

        <!-- Stock -->
        <VBox spacing="5">
            <Label text="Stock Quantity" styleClass="form-label"/>
            <TextField fx:id="stockField" promptText="0" styleClass="form-field" prefWidth="400"/>
            <Label text="Quantité entre 0 et 10000 unités" 
                   style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF; -fx-font-style: italic;"/>
        </VBox>

        <!-- Sizes (for Merch only) -->
        <VBox fx:id="sizesVBox" spacing="5" visible="false" managed="false">
            <Label text="Available Sizes" styleClass="form-label"/>
            <HBox spacing="10">
                <CheckBox fx:id="sizeSCheckBox" text="S"/>
                <CheckBox fx:id="sizeMCheckBox" text="M"/>
                <CheckBox fx:id="sizeLCheckBox" text="L"/>
                <CheckBox fx:id="sizeXLCheckBox" text="XL"/>
            </HBox>
            <Label text="Au moins une taille doit être sélectionnée pour les produits Merch" 
                   style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF; -fx-font-style: italic;"/>
        </VBox>

        <!-- Preview -->
        <VBox fx:id="previewVBox" spacing="10" visible="true" managed="true">
            <Separator/>
            <Label text="Preview" style="-fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>
            <VBox styleClass="product-card" alignment="CENTER" spacing="10" prefWidth="400">
                <ImageView fx:id="previewImageView" fitWidth="100" fitHeight="100" preserveRatio="true"/>
                <Label fx:id="previewNameLabel" text="Product Name" styleClass="product-title"/>
                <Label fx:id="previewPriceLabel" text="0.00 TND" styleClass="product-price"/>
                <Label fx:id="previewStockLabel" text="In Stock" styleClass="product-stock"/>
            </VBox>
        </VBox>

    </VBox>

    <!-- Action Buttons -->
    <HBox spacing="20" alignment="CENTER">
        <Button fx:id="saveButton" text="Save Product" styleClass="button-success" prefWidth="150" onAction="#saveProduct"/>
        <Button fx:id="resetButton" text="Reset Form" styleClass="button-secondary" prefWidth="150" onAction="#resetForm"/>
        <Button text="Cancel" styleClass="button-danger" prefWidth="150" onAction="#cancelForm"/>
    </HBox>

    <!-- Status Message -->
    <Label fx:id="statusLabel" text="" 
           style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;"/>

</VBox>
    
</ScrollPane>
