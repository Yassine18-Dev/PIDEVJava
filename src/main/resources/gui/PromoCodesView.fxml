<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>

<VBox fx:controller="controllers.PromoCodesController"
      xmlns:fx="http://javafx.com/fxml"
      spacing="20" styleClass="content-area"
      prefWidth="1200" prefHeight="800"
      style="-fx-background-color: #0F172A;"
      stylesheets="@../styles.css">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20" styleClass="form-header">
        <Button text="← Back" styleClass="button-secondary" onAction="#goBack"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Promo Codes Management"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>
    </HBox>

    <!-- Create Promo Code Form -->
    <VBox spacing="15" styleClass="product-card" prefWidth="1160" alignment="CENTER">
        <Label text="Create New Promo Code" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>
        <HBox spacing="10" alignment="CENTER">
            <TextField fx:id="promoCodeField" promptText="Code (e.g., SUMMER2024)" prefWidth="150"
                      style="-fx-background-color: #1E293B; -fx-text-fill: #FFFFFF; -fx-border-color: #475569; -fx-border-radius: 5; -fx-background-radius: 5;"/>
            <ComboBox fx:id="promoTypeCombo" promptText="Type" prefWidth="120"
                      style="-fx-background-color: #1E293B; -fx-text-fill: #FFFFFF; -fx-border-color: #475569;"/>
            <TextField fx:id="promoValueField" promptText="Value" prefWidth="100"
                      style="-fx-background-color: #1E293B; -fx-text-fill: #FFFFFF; -fx-border-color: #475569; -fx-border-radius: 5; -fx-background-radius: 5;"/>
            <TextField fx:id="promoMaxUsageField" promptText="Max Usage (0 = unlimited)" prefWidth="150"
                      style="-fx-background-color: #1E293B; -fx-text-fill: #FFFFFF; -fx-border-color: #475569; -fx-border-radius: 5; -fx-background-radius: 5;"/>
            <DatePicker fx:id="promoExpirationDatePicker" promptText="Expiration Date" prefWidth="150"
                        style="-fx-background-color: #1E293B; -fx-text-fill: #FFFFFF; -fx-border-color: #475569;"/>
            <Button text="Create" styleClass="button-success" prefWidth="100" onAction="#createPromoCode"/>
        </HBox>
        <Label fx:id="statusLabel" text=""
               style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;"/>
    </VBox>

    <!-- Promo Codes List -->
    <ScrollPane prefHeight="500" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
        <VBox fx:id="promoCodesVBox" spacing="15" prefWidth="1160"/>
    </ScrollPane>

</VBox>
