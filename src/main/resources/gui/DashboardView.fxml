<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<VBox fx:controller="controllers.DashboardController"
      xmlns:fx="http://javafx.com/fxml"
      spacing="30" alignment="CENTER"
      styleClass="content-area"
      prefWidth="800" prefHeight="600"
      stylesheets="@../styles.css">

    <!-- Header -->
    <Label text="Dashboard" 
           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>

    <!-- Stats Cards -->
    <HBox spacing="40" alignment="CENTER">
        
        <!-- Total Products Card -->
        <VBox styleClass="product-card" alignment="CENTER" spacing="15" prefWidth="250" prefHeight="150">
            <ImageView fitWidth="60" fitHeight="60" preserveRatio="true">
                <image>
                    <Image url="@../images/products.png"/>
                </image>
            </ImageView>
            <Label text="Total Products" style="-fx-font-size: 16px; -fx-text-fill: #7F8C8D;"/>
            <Label fx:id="totalProductsLabel" text="0" styleClass="product-price"/>
            <Button text="View All" styleClass="button-primary" onAction="#showAllProducts"/>
        </VBox>
        
        <!-- Skins Card -->
        <VBox styleClass="product-card" alignment="CENTER" spacing="15" prefWidth="250" prefHeight="150">
            <ImageView fitWidth="60" fitHeight="60" preserveRatio="true">
                <image>
                    <Image url="@../images/skins.png"/>
                </image>
            </ImageView>
            <Label text="Skins" style="-fx-font-size: 16px; -fx-text-fill: #7F8C8D;"/>
            <Label fx:id="totalSkinsLabel" text="0" styleClass="product-price"/>
            <Button text="View Skins" styleClass="button-primary" onAction="#showSkins"/>
        </VBox>
        
        <!-- Merch Card -->
        <VBox styleClass="product-card" alignment="CENTER" spacing="15" prefWidth="250" prefHeight="150">
            <ImageView fitWidth="60" fitHeight="60" preserveRatio="true">
                <image>
                    <Image url="@../images/merch.png"/>
                </image>
            </ImageView>
            <Label text="Merch" style="-fx-font-size: 16px; -fx-text-fill: #7F8C8D;"/>
            <Label fx:id="totalMerchLabel" text="0" styleClass="product-price"/>
            <Button text="View Merch" styleClass="button-primary" onAction="#showMerch"/>
        </VBox>
    </HBox>

    <!-- Recent Products -->
    <VBox spacing="20" prefWidth="800">
        <Label text="Recent Products" 
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
        
        <ScrollPane prefHeight="200" fitToWidth="true">
            <FlowPane fx:id="recentProductsPane" hgap="20" vgap="20" prefWidth="780"/>
        </ScrollPane>
    </VBox>

    <!-- Quick Actions -->
    <HBox spacing="20" alignment="CENTER">
        <Button text="Add New Product" styleClass="button-success" prefWidth="200" onAction="#showAddProduct"/>
        <Button text="View All Products" styleClass="button-secondary" prefWidth="200" onAction="#showAllProducts"/>
        <Button text="Refresh Dashboard" styleClass="button-secondary" prefWidth="200" onAction="#refreshDashboard"/>
    </HBox>

</VBox>
