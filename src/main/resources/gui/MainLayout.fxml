<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<BorderPane fx:controller="controllers.MainController"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="1200" prefHeight="700"
            style="-fx-background-color: #0F172A;"
            stylesheets="@../styles.css">

    <!-- TOP BAR -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT">
            <Label text="Esports Shop Dashboard" styleClass="top-bar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: white; -fx-font-size: 12px;"/>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="200">
            <VBox alignment="TOP_LEFT" spacing="10" styleClass="menu-container">
                <Label text="🏪 Shop" style="-fx-text-fill: #9CA3AF; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Button text="Dashboard" styleClass="sidebar-button button-success" onAction="#showDashboard"/>
                <Button text="Skins" styleClass="sidebar-button button-success" onAction="#showSkins"/>
                <Button text="Merch" styleClass="sidebar-button button-success" onAction="#showMerch"/>
                <Button text="All Products" styleClass="sidebar-button button-success" onAction="#showAllProducts"/>
                <Button text="Add Product" styleClass="sidebar-button button-success" onAction="#showAddProduct"/>
                <Button text="Product Management" styleClass="sidebar-button button-success" onAction="#showProductManagement"/>
                <Button text="Promotions Management" styleClass="sidebar-button button-success" onAction="#showPromoCodes"/>
                <Button text="Cart" styleClass="sidebar-button button-success" onAction="#showCart"/>
            </VBox>
            <Separator style="-fx-background-color: #374151;"/>
            <VBox alignment="TOP_LEFT" spacing="10" styleClass="menu-container">
                <Label text="🎮 Player" style="-fx-text-fill: #9CA3AF; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Button text="Player Profile" styleClass="sidebar-button button-success" onAction="#showPlayerProfile"/>
                <Button text="My Team" styleClass="sidebar-button button-success" onAction="#showTeamView"/>
                <Button text="Available Teams" styleClass="sidebar-button button-success" onAction="#showAvailableTeams"/>
                <Button text="My Requests" styleClass="sidebar-button button-success" onAction="#showMyRequests"/>
                <Button text="Invitations" styleClass="sidebar-button button-success" onAction="#showInvitations"/>
            </VBox>
            <Separator style="-fx-background-color: #374151;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Label text="Version 1.0" style="-fx-text-fill: #9CA3AF; -fx-font-size: 10px;"/>
        </VBox>
    </left>

    <!-- CONTENT AREA -->
    <center>
        <AnchorPane fx:id="contentArea" styleClass="content-area" style="-fx-background-color: #0F172A;">
            <!-- Default Dashboard View -->
            <VBox alignment="CENTER" spacing="20" AnchorPane.topAnchor="50.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.bottomAnchor="50.0" style="-fx-background-color: #0F172A;">
                <Label text="Dashboard" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>
                
                <HBox spacing="30" alignment="CENTER">
                    <!-- Total Products Card -->
                    <VBox styleClass="product-card" alignment="CENTER" spacing="10" prefWidth="200">
                        <Label text="Total Products" style="-fx-font-size: 14px; -fx-text-fill: #9CA3AF;"/>
                        <Label fx:id="totalProductsLabel" text="0" styleClass="product-price"/>
                    </VBox>
                    
                    <!-- Skins Card -->
                    <VBox styleClass="product-card" alignment="CENTER" spacing="10" prefWidth="200">
                        <Label text="Skins" style="-fx-font-size: 14px; -fx-text-fill: #9CA3AF;"/>
                        <Label fx:id="totalSkinsLabel" text="0" styleClass="product-price"/>
                    </VBox>
                    
                    <!-- Merch Card -->
                    <VBox styleClass="product-card" alignment="CENTER" spacing="10" prefWidth="200">
                        <Label text="Merch" style="-fx-font-size: 14px; -fx-text-fill: #9CA3AF;"/>
                        <Label fx:id="totalMerchLabel" text="0" styleClass="product-price"/>
                    </VBox>
                </HBox>
                
                <Button text="View All Products" styleClass="button-primary" onAction="#showAllProducts"/>
            </VBox>
        </AnchorPane>
    </center>

</BorderPane>