<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" stylesheets="@styles.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" fx:controller="controllers.AjouterPostController">
   <children>
      <VBox layoutX="257.0" layoutY="53.0" prefHeight="273.0" prefWidth="166.0">
         <children>
            <Label text="Titre ">
               <VBox.margin>
                  <Insets bottom="5.0" top="5.0" />
               </VBox.margin>
            </Label>
            <TextField fx:id="titreInput" />
            <Label text="Contenu">
               <VBox.margin>
                  <Insets bottom="5.0" top="5.0" />
               </VBox.margin>
            </Label>
            <TextArea fx:id="contenuInput" prefHeight="108.0" prefWidth="166.0" />
            <Label text="URL Image">
               <VBox.margin>
                  <Insets bottom="5.0" top="5.0" />
               </VBox.margin>
            </Label>
            <HBox spacing="5">
               <children>
                  <TextField fx:id="imageInput" HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnSelectImage" mnemonicParsing="false" onAction="#onSelectImage" text="📁" />
               </children>
            </HBox>
            <Button fx:id="btnAjouter" alignment="CENTER" mnemonicParsing="false" onAction="#onAjouterPost" text="Ajouter le post ">
               <VBox.margin>
                  <Insets left="33.0" top="20.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </children>
</AnchorPane>